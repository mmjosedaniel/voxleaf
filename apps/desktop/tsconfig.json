{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["@testing-library/jest-dom", "vite/client", "vitest/globals"]
  },
  "include": [
    "playwright.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "vite.config.ts"
  ]
}
