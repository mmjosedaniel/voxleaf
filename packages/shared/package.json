{
  "name": "@voxleaf/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "generate": "node scripts/generate-contracts.mjs",
    "generate:check": "node scripts/generate-contracts.mjs --check",
    "pretest": "pnpm run generate:check && pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.test.json"
  }
}
